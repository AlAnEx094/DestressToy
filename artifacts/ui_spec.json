{
  "meta": {
    "project_name": "DeStressToys",
    "screen_type": "landing",
    "goal": "collect leads — free brand-object concept request",
    "style": "Tactile Editorial Premium",
    "responsive_priority": "desktop-first",
    "reference": "reference_b.png"
  },

  "layout": {
    "max_width": "1280px",
    "grid_type": "12-column",
    "container_padding": {
      "desktop": "80px",
      "tablet": "40px",
      "mobile": "20px"
    },
    "section_vertical_spacing": {
      "desktop": "96px",
      "tablet": "64px",
      "mobile": "48px"
    }
  },

  "theme": {
    "colors": {
      "dark": "#151716",
      "sandy": "#f4efe8",
      "light": "#ebe5dd",
      "coral": "#ff6a3d",
      "gray_green": "#7c847d",
      "white": "#ffffff"
    },
    "section_backgrounds": {
      "header": "#151716",
      "hero": "#151716",
      "comparison": "#f4efe8",
      "why_it_works": "#f4efe8",
      "texture": "#151716",
      "gallery": "#ebe5dd",
      "welcome_box": "#f4efe8",
      "process": "#151716",
      "use_cases": "#f4efe8",
      "trust": "#ebe5dd",
      "faq": "#f4efe8",
      "final_cta": "#151716",
      "footer": "#151716"
    },
    "border_radius": {
      "button": "6px",
      "card": "12px",
      "input": "6px",
      "tag": "4px"
    },
    "shadow": "none"
  },

  "typography": {
    "font_family": "Inter, sans-serif",
    "scale": {
      "display": { "size": "64px", "weight": "700", "line_height": "1.05", "tracking": "-0.02em" },
      "h1":      { "size": "56px", "weight": "700", "line_height": "1.1",  "tracking": "-0.02em" },
      "h2":      { "size": "40px", "weight": "700", "line_height": "1.15", "tracking": "-0.01em" },
      "h3":      { "size": "24px", "weight": "600", "line_height": "1.3",  "tracking": "0" },
      "h4":      { "size": "18px", "weight": "600", "line_height": "1.4",  "tracking": "0" },
      "body_lg": { "size": "18px", "weight": "400", "line_height": "1.6",  "tracking": "0" },
      "body":    { "size": "16px", "weight": "400", "line_height": "1.6",  "tracking": "0" },
      "body_sm": { "size": "14px", "weight": "400", "line_height": "1.5",  "tracking": "0" },
      "label":   { "size": "12px", "weight": "500", "line_height": "1.4",  "tracking": "0.06em", "text_transform": "uppercase" },
      "number":  { "size": "48px", "weight": "700", "line_height": "1",    "tracking": "-0.02em" }
    },
    "color_on_dark": "#ffffff",
    "color_on_light": "#151716",
    "secondary_on_dark": "#7c847d",
    "secondary_on_light": "#7c847d"
  },

  "components": {
    "button_primary": {
      "background": "#ff6a3d",
      "text_color": "#ffffff",
      "font_size": "16px",
      "font_weight": "600",
      "padding": "14px 28px",
      "border_radius": "6px",
      "border": "none",
      "hover_background": "#e85a2e"
    },
    "button_ghost": {
      "background": "transparent",
      "text_color": "#ffffff",
      "font_size": "16px",
      "font_weight": "500",
      "padding": "14px 24px",
      "border_radius": "6px",
      "border": "1px solid rgba(255,255,255,0.3)",
      "hover_border": "1px solid rgba(255,255,255,0.7)"
    },
    "card_light": {
      "background": "#ffffff",
      "border": "1px solid #e5e0d8",
      "border_radius": "12px",
      "padding": "32px",
      "shadow": "none"
    },
    "card_sandy": {
      "background": "#ebe5dd",
      "border": "none",
      "border_radius": "12px",
      "padding": "32px",
      "shadow": "none"
    },
    "card_dark": {
      "background": "rgba(255,255,255,0.05)",
      "border": "1px solid rgba(255,255,255,0.1)",
      "border_radius": "12px",
      "padding": "32px",
      "shadow": "none"
    },
    "nav_link": {
      "color": "#7c847d",
      "font_size": "15px",
      "font_weight": "500",
      "hover_color": "#ffffff"
    },
    "input": {
      "background": "#ffffff",
      "border": "1px solid #d0c9bf",
      "border_radius": "6px",
      "padding": "12px 16px",
      "font_size": "16px",
      "color": "#151716",
      "placeholder_color": "#7c847d",
      "focus_border": "#ff6a3d"
    },
    "textarea": {
      "rows": 4,
      "same_as_input": true
    },
    "faq_item": {
      "border_bottom": "1px solid #d0c9bf",
      "padding": "20px 0",
      "question_weight": "600",
      "answer_color": "#7c847d"
    },
    "section_label": {
      "color": "#ff6a3d",
      "font": "label scale",
      "margin_bottom": "16px"
    }
  },

  "sections": [
    {
      "id": "header",
      "order": 0,
      "background": "#151716",
      "sticky": true,
      "height": "64px",
      "layout": "flex space-between align-center",
      "content": {
        "logo": "DS — text mark, white, font-size 22px, font-weight 700",
        "nav_links": ["Продукт", "Примеры", "Процесс", "О нас", "FAQ"],
        "cta_button": "Запросить концепт — button_primary style, smaller: padding 10px 20px"
      }
    },
    {
      "id": "hero",
      "order": 1,
      "background": "#151716",
      "layout": "two-column, 55%/45%",
      "min_height": "90vh",
      "padding_top": "80px",
      "content": {
        "left_column": {
          "eyebrow_label": "Кастомные бренд-объекты для компаний",
          "headline": "Бренд-объект, который не теряется среди обычного мерча",
          "subheadline": "Мягкие объекты кастомной формы — логотип, маскот или символ бренда. Тактильный предмет, который остаётся в руках и на столе.",
          "cta_primary": "Запросить концепт",
          "cta_note": "Концепт бесплатно · Ответим за 1 рабочий день",
          "proof_points": [
            "Форма под любой бренд",
            "Тираж от 50 штук",
            "Производство под ключ"
          ]
        },
        "right_column": {
          "content": "product hero image — large close-up of soft branded object on dark/neutral background",
          "image_aspect": "portrait, fills column height",
          "placeholder": "bg-gray-800 rounded-2xl with centered text 'Product Photo'"
        }
      },
      "visual_rules": {
        "headline_tag": "h1",
        "headline_max_width": "580px",
        "eyebrow_color": "#ff6a3d",
        "headline_color": "#ffffff",
        "sub_color": "#7c847d",
        "proof_points_style": "flex row, gap 24px, body_sm, gray-green, with dot separator",
        "cta_note_color": "#7c847d",
        "cta_note_size": "14px"
      }
    },
    {
      "id": "comparison",
      "order": 2,
      "background": "#f4efe8",
      "layout": "two-column equal, centered in container",
      "content": {
        "section_label": "Сравнение",
        "left_column_title": "Обычный мерч",
        "right_column_title": "Бренд-объект DeStressToys",
        "rows": [
          { "left": "Стандартная форма", "right": "Уникальная форма под бренд" },
          { "left": "Быстро теряется", "right": "Остаётся в руках и на столе" },
          { "left": "Не вызывает эмоций", "right": "Вызывает тактильный отклик" },
          { "left": "Одноразовое использование", "right": "Используется регулярно" },
          { "left": "Безликий", "right": "Полностью кастомный — ваш бренд" }
        ]
      },
      "visual_rules": {
        "left_title_color": "#7c847d",
        "right_title_color": "#151716",
        "right_title_has_coral_underline": true,
        "row_separator": "1px solid #d0c9bf",
        "left_text_color": "#7c847d",
        "right_text_color": "#151716",
        "right_row_has_checkmark": true,
        "checkmark_color": "#ff6a3d"
      }
    },
    {
      "id": "why_it_works",
      "order": 3,
      "background": "#f4efe8",
      "layout": "3-column card grid",
      "content": {
        "section_label": "Почему это работает",
        "section_title": "Тактильный контакт работает там, где визуальный — нет",
        "cards": [
          {
            "number": "01",
            "title": "Тактильный контакт",
            "body": "Физический объект активирует несколько органов чувств одновременно — запоминаемость в разы выше, чем у визуального мерча."
          },
          {
            "number": "02",
            "title": "Эмоциональная связь",
            "body": "Мягкость и форма вашего бренда создают положительную ассоциацию каждый раз, когда объект берут в руки."
          },
          {
            "number": "03",
            "title": "Долгий эффект",
            "body": "Бренд-объект остаётся на столе неделями. Среднее время жизни — в 8 раз дольше стандартного промо-предмета."
          }
        ]
      },
      "visual_rules": {
        "card_style": "card_light",
        "number_color": "#ff6a3d",
        "number_font": "number scale",
        "title_font": "h3",
        "body_font": "body",
        "body_color": "#7c847d",
        "grid_gap": "24px"
      }
    },
    {
      "id": "texture",
      "order": 4,
      "background": "#151716",
      "layout": "two-column 50%/50%",
      "content": {
        "left_column": {
          "section_label": "Материал",
          "title": "Приятно держать. Сложно отложить.",
          "body": "Мягкий пенополиуретан с бархатистым покрытием. Объект пружинит и возвращает форму — руки тянутся к нему снова и снова.",
          "details": [
            "Покрытие: бархатистый PU",
            "Наполнитель: медленно восстанавливающийся foam",
            "Безопасен: сертификат CE, без латекса",
            "Долговечность: 3+ года активного использования"
          ]
        },
        "right_column": {
          "content": "close-up texture photo — surface of soft branded object, macro shot",
          "placeholder": "bg-gray-800 rounded-2xl h-96"
        }
      },
      "visual_rules": {
        "label_color": "#ff6a3d",
        "title_color": "#ffffff",
        "body_color": "#7c847d",
        "details_style": "list with coral dot, body_sm, gray-green",
        "column_gap": "80px"
      }
    },
    {
      "id": "gallery",
      "order": 5,
      "background": "#ebe5dd",
      "layout": "masonry-like grid: 2 large + 3 small",
      "content": {
        "section_label": "Примеры",
        "section_title": "Реализованные бренд-объекты",
        "items": [
          { "label": "Логотип-антистресс", "placeholder": true },
          { "label": "Маскот бренда", "placeholder": true },
          { "label": "Фирменный символ", "placeholder": true },
          { "label": "Промо-фигура", "placeholder": true },
          { "label": "Welcome kit объект", "placeholder": true }
        ]
      },
      "visual_rules": {
        "item_border_radius": "12px",
        "item_background": "#d0c9bf",
        "label_position": "bottom-left overlay",
        "label_color": "#ffffff",
        "label_bg": "rgba(21,23,22,0.6)",
        "label_font": "body_sm",
        "grid_gap": "16px"
      }
    },
    {
      "id": "welcome_box",
      "order": 6,
      "background": "#f4efe8",
      "layout": "two-column 45%/55%",
      "content": {
        "section_label": "Welcome Kit",
        "title": "Стать частью welcome kit — и остаться на столе",
        "body": "Бренд-объект в составе корпоративного набора — первое физическое впечатление нового сотрудника или клиента. Формирует принадлежность с первого дня.",
        "tags": ["Welcome kit", "Промонаборы", "Event-пакеты", "Подарки партнёрам"],
        "cta": "Запросить концепт"
      },
      "visual_rules": {
        "tags_style": "pill, border 1px solid #d0c9bf, body_sm, color #7c847d, padding 6px 14px",
        "right_column": "product-in-box photo placeholder, rounded-2xl"
      }
    },
    {
      "id": "process",
      "order": 7,
      "background": "#151716",
      "layout": "4 steps horizontal on desktop, vertical on mobile",
      "content": {
        "section_label": "Процесс",
        "section_title": "От заявки до готового объекта",
        "steps": [
          {
            "number": "01",
            "title": "Заявка",
            "body": "Заполните форму — опишите задачу, бренд и контекст использования."
          },
          {
            "number": "02",
            "title": "Концепт",
            "body": "В течение 1 рабочего дня пришлём концепт формы с рендером и описанием."
          },
          {
            "number": "03",
            "title": "Согласование",
            "body": "Утвердим детали: форма, размер, цвет, тираж. Внесём правки бесплатно."
          },
          {
            "number": "04",
            "title": "Производство",
            "body": "Изготовим и доставим. Срок производства — 3–5 недель от утверждения."
          }
        ]
      },
      "visual_rules": {
        "number_color": "#ff6a3d",
        "title_color": "#ffffff",
        "body_color": "#7c847d",
        "step_connector": "horizontal line between steps, color rgba(255,255,255,0.1), desktop only",
        "step_min_width": "220px"
      }
    },
    {
      "id": "use_cases",
      "order": 8,
      "background": "#f4efe8",
      "layout": "2x2 card grid",
      "content": {
        "section_label": "Где используют",
        "section_title": "Подходит для любой точки контакта с брендом",
        "cases": [
          {
            "title": "Event и выставки",
            "body": "Раздаточный материал, который не выбрасывают. Логотип-антистресс остаётся на столе после мероприятия.",
            "icon": "🎪"
          },
          {
            "title": "Welcome kit",
            "body": "Первый физический предмет бренда в руках нового сотрудника или клиента. Формирует принадлежность.",
            "icon": "📦"
          },
          {
            "title": "Подарки партнёрам",
            "body": "Статусный корпоративный подарок с индивидуальной формой. Не безликий мерч — авторский объект.",
            "icon": "🤝"
          },
          {
            "title": "Промо-рассылки",
            "body": "Вкладыш в почтовую рассылку, который открывают и держат в руках. CTR таких рассылок выше на 40%.",
            "icon": "📬"
          }
        ]
      },
      "visual_rules": {
        "card_style": "card_light",
        "icon_size": "32px",
        "icon_margin_bottom": "16px",
        "title_font": "h3",
        "body_color": "#7c847d",
        "grid_gap": "24px"
      }
    },
    {
      "id": "trust",
      "order": 9,
      "background": "#ebe5dd",
      "layout": "stacked: logos row + testimonial + risk-reducers row",
      "content": {
        "section_label": "Доверие",
        "logos_row": {
          "label": "Бренды, которые уже сделали свой объект",
          "count": 6,
          "placeholder": true
        },
        "testimonial": {
          "quote": "Раньше мы дарили ручки и блокноты. После того как сделали фигуру нашего маскота — клиенты сами присылают фото с ним. Это стало частью бренда.",
          "author": "Алёна М., Head of Marketing, Placeholder Company",
          "placeholder": true
        },
        "risk_reducers": [
          { "title": "Минимальный тираж", "value": "от 50 шт." },
          { "title": "Концепт бесплатно", "value": "без предоплаты" },
          { "title": "Срок производства", "value": "3–5 недель" },
          { "title": "Правки до утверждения", "value": "бесплатно" }
        ]
      },
      "visual_rules": {
        "logo_placeholder_style": "rounded bg-gray-300 h-8 w-24",
        "testimonial_card_style": "card_light, max-width 720px, centered",
        "quote_font": "body_lg",
        "quote_color": "#151716",
        "author_color": "#7c847d",
        "risk_item_style": "flex column, value font h3 color #151716, label body_sm color #7c847d"
      }
    },
    {
      "id": "faq",
      "order": 10,
      "background": "#f4efe8",
      "layout": "single column, max-width 720px centered",
      "content": {
        "section_label": "FAQ",
        "section_title": "Частые вопросы",
        "items": [
          {
            "q": "Какой минимальный тираж?",
            "a": "От 50 штук. Для крупных тиражей (500+) доступны дополнительные скидки."
          },
          {
            "q": "Из чего делают объекты?",
            "a": "Мягкий пенополиуретан с бархатистым PU-покрытием. Сертификат CE, безопасен для взрослых и детей от 3 лет."
          },
          {
            "q": "Сколько занимает производство?",
            "a": "3–5 недель от утверждения финального концепта. Срочные заказы обсуждаются индивидуально."
          },
          {
            "q": "Какие форматы кастомизации доступны?",
            "a": "Любая 3D-форма: логотип, маскот, символ, продукт компании. Доступны также кастомный цвет и брендированная упаковка."
          },
          {
            "q": "Как происходит доставка?",
            "a": "Доставляем по России и СНГ. Возможна доставка до склада или прямая развозка на мероприятие."
          },
          {
            "q": "Сколько стоит?",
            "a": "Стоимость зависит от формы, тиража и сложности. Концепт и расчёт цены — бесплатно, после заявки."
          },
          {
            "q": "Можно ли получить образец перед тиражом?",
            "a": "Да, производим тестовый образец. Стоимость образца засчитывается в тираж при подтверждении заказа."
          }
        ]
      },
      "visual_rules": {
        "item_style": "faq_item component",
        "expand_indicator": "'+' / '−' right-aligned, color #ff6a3d",
        "default_state": "all collapsed"
      }
    },
    {
      "id": "final_cta",
      "order": 11,
      "background": "#151716",
      "layout": "two-column 45%/55% on desktop, stacked on mobile",
      "content": {
        "left_column": {
          "section_label": "Запрос концепта",
          "title": "Запросить концепт под ваш бренд",
          "body": "Опишите задачу — пришлём концепт бесплатно в течение 1 рабочего дня.",
          "guarantees": [
            "Без предоплаты",
            "Правки бесплатно",
            "Ответим за 1 день"
          ]
        },
        "right_column": {
          "form_fields": [
            { "id": "name",    "type": "text",     "label": "Имя",              "required": true },
            { "id": "company", "type": "text",     "label": "Компания",         "required": true },
            { "id": "email",   "type": "email",    "label": "Email",            "required": true },
            { "id": "task",    "type": "textarea", "label": "Опишите задачу",   "required": false, "rows": 4 }
          ],
          "submit_button": "Отправить заявку",
          "microcopy": "Нажимая кнопку, вы соглашаетесь с политикой конфиденциальности",
          "success_state": "Заявка принята! Свяжемся в течение 1 рабочего дня."
        }
      },
      "visual_rules": {
        "label_color": "#ff6a3d",
        "title_color": "#ffffff",
        "title_max_width": "400px",
        "body_color": "#7c847d",
        "guarantees_style": "flex column, gap 8px, body_sm, color #7c847d, with coral checkmark",
        "form_card": "card_dark — bg rgba(255,255,255,0.04), border rgba(255,255,255,0.1), border_radius 12px, padding 40px",
        "input_style": "input component",
        "submit_style": "button_primary full-width",
        "microcopy_color": "#7c847d",
        "microcopy_size": "12px",
        "privacy_link_color": "#7c847d",
        "privacy_link_underline": true
      }
    },
    {
      "id": "footer",
      "order": 12,
      "background": "#151716",
      "layout": "flex space-between, border-top 1px solid rgba(255,255,255,0.1)",
      "content": {
        "left": "© 2025 DeStressToys",
        "center": "nav links: Продукт, Примеры, Процесс, FAQ",
        "right": "Политика конфиденциальности (link to /privacy)"
      },
      "visual_rules": {
        "text_color": "#7c847d",
        "font": "body_sm",
        "padding": "32px 0"
      }
    }
  ],

  "pages": {
    "main": "/",
    "privacy": "/privacy"
  },

  "routing": {
    "library": "react-router-dom v6",
    "routes": [
      { "path": "/",       "component": "App" },
      { "path": "/privacy","component": "PrivacyPage" }
    ]
  },

  "responsive_rules": {
